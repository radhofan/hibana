# SQL Server — matches docker-compose defaults
SQLSERVER_CONNECTION=Server=localhost,1433;Database=IoTHub;User Id=sa;Password=IoTHub@2024!;TrustServerCertificate=True;

# Redis — matches docker-compose defaults
REDIS_CONNECTION=localhost:6379

# RabbitMQ — matches docker-compose defaults
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Ollama (local LLM) — matches docker-compose defaults, no account needed
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3

# Sentry Error Tracking (optional)
# Get from: https://sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=YOUR_SENTRY_DSN
